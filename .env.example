# Google OAuth2 credentials (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Refresh token (run `node auth.js` to obtain this)
GOOGLE_REFRESH_TOKEN=

# Google Sheet ID (from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Polling interval in milliseconds (default: 5000)
POLL_INTERVAL=5000

# Server port
PORT=3000

# SeaTalk / 分享：日历页公网地址（推送里「查看完整日历」链接，默认已指向当前主机）
# CALENDAR_PUBLIC_URL=http://101.133.141.32

# SeaTalk 定时推送日期控制（北京时间，YYYY-MM-DD，逗号分隔）
# 2026 示例（按国务院办公厅放假通知）：
# PUSH_HOLIDAYS=2026-01-01,2026-01-02,2026-01-03,2026-02-15,2026-02-16,2026-02-17,2026-02-18,2026-02-19,2026-02-20,2026-02-21,2026-02-22,2026-02-23,2026-04-04,2026-04-05,2026-04-06,2026-05-01,2026-05-02,2026-05-03,2026-05-04,2026-05-05,2026-06-19,2026-06-20,2026-06-21,2026-09-25,2026-09-26,2026-09-27,2026-10-01,2026-10-02,2026-10-03,2026-10-04,2026-10-05,2026-10-06,2026-10-07
# PUSH_MAKEUP_WORKDAYS=2026-01-04,2026-02-14,2026-02-28,2026-05-09,2026-09-20,2026-10-10
